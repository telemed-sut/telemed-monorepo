# Reference only. Official scripts ignore root .env and use Infisical
# or exported shell variables instead.
# If you create a local .env for one-off experiments, do not treat it as
# the source of truth for the team.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_SERVER_API_PROXY_TARGET=http://localhost:8000
NEXT_SERVER_API_BASE_URL=http://localhost:8000

# Backend core
DATABASE_URL=replace_with_postgresql_connection_string
JWT_SECRET=replace_with_a_minimum_32_character_random_secret
JWT_EXPIRES_IN=3600
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Device API security
DEVICE_API_SECRET=replace_with_a_minimum_32_character_random_secret
DEVICE_API_SECRETS={"test_device_001":"replace_with_device_specific_secret_min_32_chars"}
DEVICE_API_ALLOW_JWT_SECRET_FALLBACK=false
DEVICE_API_REQUIRE_REGISTERED_DEVICE=false
DEVICE_API_REQUIRE_BODY_HASH_SIGNATURE=false
DEVICE_API_REQUIRE_NONCE=false
DEVICE_API_NONCE_TTL_SECONDS=300
DEVICE_API_MAX_BODY_BYTES=262144

# Cookies
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
PRIVILEGED_ACTION_MFA_MAX_AGE_SECONDS=900

# Privileged admin bootstrap (do not use as day-to-day authorization source)
SUPER_ADMIN_EMAILS=admin@example.com
ADMIN_OIDC_ENABLED=false
ADMIN_OIDC_ENFORCED=false
ADMIN_OIDC_PROVIDER_NAME=authentik
ADMIN_OIDC_ISSUER_URL=http://localhost:9000/application/o/telemed-admin
ADMIN_OIDC_CLIENT_ID=telemed-admin
ADMIN_OIDC_CLIENT_SECRET=replace_with_local_authentik_client_secret
ADMIN_OIDC_REDIRECT_URI=http://localhost:3000/api/auth/admin/sso/callback
ADMIN_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/login
ADMIN_OIDC_SCOPES=openid,profile,email
ADMIN_OIDC_ALLOWED_EMAIL_DOMAINS=
ADMIN_OIDC_REQUIRED_GROUP=
ADMIN_OIDC_STATE_TTL_SECONDS=600
ADMIN_OIDC_CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379/0

# Startup
RUN_MIGRATIONS_ON_STARTUP=true
# Local-only bootstrap. Keep false outside disposable dev environments.
RUN_SEED_ON_STARTUP=false
