{
    "version": 2,
    "builds": [
        {
            "src": "simple_test.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "simple_test.py"
        }
    ],
    "env": {
        "DATABASE_URL": "$DATABASE_URL",
        "JWT_SECRET": "$JWT_SECRET", 
        "JWT_EXPIRES_IN": "$JWT_EXPIRES_IN",
        "CORS_ORIGINS": "$CORS_ORIGINS"
    }
}