# Reference only. Official backend runtime config should come from Infisical
# or exported shell variables, not from a committed local .env file.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/patient_db
JWT_SECRET=replace_with_a_minimum_32_character_random_secret
JWT_EXPIRES_IN=3600
ADMIN_JWT_EXPIRES_IN=43200
APP_ENV=development
PASSWORD_RESET_EXPIRES_IN=900
PASSWORD_RESET_RETURN_TOKEN_IN_RESPONSE=false
FRONTEND_BASE_URL=http://localhost:3000
API_DOCS_ENABLED=true
ALLOWED_HOSTS=localhost,127.0.0.1,::1
INVITE_EXPIRES_IN_HOURS=24
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
DEVICE_API_SECRET=replace_with_a_minimum_32_character_random_secret
DEVICE_API_SECRETS={"test_device_NEW_006":"replace_with_device_specific_secret_min_32_chars"}
DEVICE_API_ALLOW_JWT_SECRET_FALLBACK=false
DEVICE_API_REQUIRE_REGISTERED_DEVICE=false
DEVICE_API_REQUIRE_BODY_HASH_SIGNATURE=false
DEVICE_API_REQUIRE_NONCE=false
DEVICE_API_NONCE_TTL_SECONDS=300
DEVICE_API_MAX_BODY_BYTES=262144
AUTH_COOKIE_NAME=access_token
# Set false only for local HTTP development.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
ADMIN_OIDC_ENABLED=false
ADMIN_OIDC_ENFORCED=false
ADMIN_OIDC_PROVIDER_NAME=authentik
ADMIN_OIDC_ISSUER_URL=http://localhost:9000/application/o/telemed-admin
ADMIN_OIDC_CLIENT_ID=telemed-admin
ADMIN_OIDC_CLIENT_SECRET=replace_with_local_authentik_client_secret
ADMIN_OIDC_REDIRECT_URI=http://localhost:3000/api/auth/admin/sso/callback
ADMIN_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/login
ADMIN_OIDC_SCOPES=openid,profile,email
ADMIN_OIDC_ALLOWED_EMAIL_DOMAINS=
ADMIN_OIDC_REQUIRED_GROUP=
ADMIN_OIDC_STATE_TTL_SECONDS=600
ADMIN_OIDC_CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379/0
MAX_LOGIN_ATTEMPTS=10
ACCOUNT_LOCKOUT_MINUTES=15
ADMIN_MAX_LOGIN_ATTEMPTS=15
ADMIN_ACCOUNT_LOCKOUT_MINUTES=3
MIN_ACTIVE_ADMIN_ACCOUNTS=2
# Bootstrap / break-glass fallback only. On startup the backend will backfill
# matching admin users into DB-backed platform_super_admin assignments.
# Daily privileged access should come from DB-backed role assignments.
SUPER_ADMIN_EMAILS=admin@example.com
ADMIN_UNLOCK_WHITELISTED_IPS=127.0.0.1,::1
TRUSTED_PROXY_IPS=127.0.0.1,::1
ADMIN_2FA_REQUIRED=true
PRIVILEGED_ACTION_MFA_MAX_AGE_SECONDS=14400
ADMIN_2FA_ISSUER=Telemed Admin
TRUSTED_DEVICE_COOKIE_NAME=trusted_device_token
ADMIN_TRUSTED_DEVICE_DAYS=7
USER_TRUSTED_DEVICE_DAYS=30
BACKUP_CODE_COUNT=10
BACKUP_CODE_EXPIRES_DAYS=365
RUN_MIGRATIONS_ON_STARTUP=true
# Local-only bootstrap. Keep false outside disposable dev environments.
RUN_SEED_ON_STARTUP=false

# Novu Notifications (optional)
NOVU_API_KEY=replace_with_novu_api_key
NOVU_ENABLED=true

# Video Meeting Provider (disabled | mock | zego)
MEETING_VIDEO_PROVIDER=disabled
MEETING_VIDEO_TOKEN_TTL_SECONDS=900
MEETING_PATIENT_INVITE_TTL_SECONDS=86400
MEETING_PATIENT_JOIN_BASE_URL=
MEETING_VIDEO_ROOM_PREFIX=telemed
# Required only when MEETING_VIDEO_PROVIDER=zego
ZEGO_APP_ID=
ZEGO_SERVER_SECRET=
