{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:3000/"
      ],
      "numberOfRuns": 3,
      "startServerCommand": "cd frontend && bun run start -- --port 3000 --hostname 127.0.0.1",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 120000,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 2500
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "total-blocking-time": [
          "error",
          {
            "maxNumericValue": 100
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
