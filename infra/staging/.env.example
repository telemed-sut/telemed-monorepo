BACKEND_IMAGE=ghcr.io/telemed-sut/telemed-backend:latest
FRONTEND_IMAGE=ghcr.io/telemed-sut/telemed-frontend:latest

FRONTEND_PORT=3000
BACKEND_PORT=8000

DATABASE_URL=postgresql+psycopg://user:password@your-managed-postgres-host:5432/patient_db
JWT_SECRET=replace_with_a_minimum_32_character_random_secret
JWT_EXPIRES_IN=3600
ADMIN_JWT_EXPIRES_IN=14400
DEVICE_API_SECRET=replace_with_a_minimum_32_character_random_secret
CORS_ORIGINS=https://staging.example.com
FRONTEND_BASE_URL=https://staging.example.com
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
PRIVILEGED_ACTION_MFA_MAX_AGE_SECONDS=900
ADMIN_OIDC_ENABLED=false
ADMIN_OIDC_ENFORCED=false
ADMIN_OIDC_PROVIDER_NAME=authentik
ADMIN_OIDC_ISSUER_URL=https://sso-staging.example.com/application/o/telemed-admin
ADMIN_OIDC_CLIENT_ID=telemed-admin
ADMIN_OIDC_CLIENT_SECRET=replace_with_oidc_client_secret
ADMIN_OIDC_REDIRECT_URI=https://staging.example.com/api/auth/admin/sso/callback
ADMIN_OIDC_POST_LOGOUT_REDIRECT_URI=https://staging.example.com/login
ADMIN_OIDC_SCOPES=openid,profile,email
ADMIN_OIDC_ALLOWED_EMAIL_DOMAINS=example.com
ADMIN_OIDC_REQUIRED_GROUP=telemed-admins
ADMIN_OIDC_STATE_TTL_SECONDS=600
ADMIN_OIDC_CACHE_TTL_SECONDS=3600
REDIS_URL=redis://:replace_with_redis_password@redis:6379/0

RUN_MIGRATIONS_ON_STARTUP=true
RUN_SEED_ON_STARTUP=false

NEXT_PUBLIC_API_BASE_URL=/api
NEXT_SERVER_API_PROXY_TARGET=http://backend:8000
NEXT_SERVER_API_BASE_URL=http://backend:8000

AUTHENTIK_IMAGE=ghcr.io/goauthentik/server:latest
AUTHENTIK_SECRET_KEY=replace_with_authentik_secret_key
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_PASSWORD=replace_with_authentik_db_password
AUTHENTIK_REDIS_PASSWORD=replace_with_authentik_redis_password
AUTHENTIK_POSTGRES_DB=authentik
AUTHENTIK_PORT=9000
